    "html": "<html lang=\"en\" class=\"w-100 h-100\"><head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <link rel=\"shortcut icon\" href=\"/favicon.ico\" type=\"image/x-icon\">\n\n  <title>Dokumentasi API Cek Ongkir - BinderByte</title>\n  <meta name=\"description\" content=\"API Cek Ongkir adalah api yang berguna untuk cek tarif atau ongkir dari berbagai macam ekspedisi mulai dari jne, sicepat, pos, anteraja, lion, sap, ide dll\">\n  <meta name=\"robots\" content=\"index, follow\">\n  <meta name=\"author\" content=\"Aan Aliudin\">\n  <link rel=\"canonical\" href=\"https://binderbyte.com/\">\n\n  <meta property=\"og:title\" content=\"Dokumentasi API Cek Ongkir - BinderByte\">\n  <meta property=\"og:description\" content=\"API Cek Ongkir adalah api yang berguna untuk cek tarif atau ongkir dari berbagai macam ekspedisi mulai dari jne, sicepat, pos, anteraja, lion, sap, ide dll\">\n  <meta property=\"og:url\" content=\"https://binderbyte.com/api/cek-tarif\">\n\n  <link href=\"https://fonts.googleapis.com/css2?family=Sarabun:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800&amp;display=swap\" rel=\"stylesheet\">\n  <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/MaterialDesign-Webfont/5.5.55/css/materialdesignicons.min.css\">\n  <link rel=\"stylesheet\" href=\"https://binderbyte.com/assets/font-awesome/css/all.min.css\">\n  <link rel=\"stylesheet\" href=\"https://binderbyte.com/assets/waves-effect/css/waves.min.css\">\n  <link rel=\"stylesheet\" href=\"https://binderbyte.com/assets/bs5/css/bootstrap.min.css\">\n  <link rel=\"stylesheet\" href=\"https://binderbyte.com/assets/templates/css/whatsapp.css\">\n  <style>\n    html,\n    body {\n      scroll-behavior: smooth;\n      position: relative !important;\n    }\n\n    ::-webkit-scrollbar {\n      width: 0 !important;\n    }\n\n    ::selection {\n      background: #000;\n      color: #fff;\n    }\n\n    .btn:focus {\n      outline: none !important;\n      box-shadow: none !important;\n    }\n  </style>\n\n</head>\n\n<body class=\"w-100 h-100\"><!-- CSS -->\n<link rel=\"stylesheet\" href=\"https://binderbyte.com/assets/highlightjs/css/atom-one-dark.css\">\n\n<!-- NAVBAR -->\n<nav id=\"navbar\" class=\"navbar navbar-expand-lg navbar-dark fixed-top\" style=\"background-color: transparent;\">\n  <div class=\"container py-3\">\n\n    <a class=\"navbar-brand\" href=\"https://binderbyte.com/\">\n      <img src=\"/assets/img/long-logo.svg\" class=\"d-none d-lg-block\" height=\"30\" loading=\"lazy\">\n      <img src=\"/assets/img/logo.svg\" class=\"d-block d-lg-none\" height=\"30\" loading=\"lazy\">\n    </a>\n\n    <button class=\"navbar-toggler\" type=\"button\" data-toggle=\"collapse\" data-target=\"#navbarNavAltMarkup\" aria-controls=\"navbarNavAltMarkup\" aria-expanded=\"false\" aria-label=\"Toggle navigation\">\n      <span class=\"navbar-toggler-icon\"></span>\n    </button>\n\n        <div class=\"mt-3 mt-lg-0 collapse navbar-collapse\" id=\"navbarNavAltMarkup\">\n      <div class=\"ml-auto navbar-nav nav-pills\">\n        <a class=\"my-1 text-center nav-link my-lg-0 mx-lg-2 \" href=\"https://binderbyte.com/\">Home</a>\n          <a class=\"my-1 text-center nav-link my-lg-0 mx-lg-2\" href=\"https://binderbyte.com/#product\">Product</a>\n          <a class=\"my-1 text-center nav-link my-lg-0 mx-lg-2\" href=\"https://binderbyte.com/#features\">Feature</a>\n          <a class=\"my-1 text-center nav-link my-lg-0 mx-lg-2\" href=\"https://binderbyte.com/#faq\">FAQ</a>\n        <li class=\"nav-item dropdown my-1 text-center my-lg-0 mx-lg-2\">\n          <a class=\"nav-link\" href=\"https://documenter.getpostman.com/view/12963788/TVRg69g4\" target=\"_blank\">\n            Documentation\n          </a>\n        </li>\n\n        <style>\n          .nav-link.active {\n            color: rgba(255, 255, 255, 1);\n            background-color: transparent !important;\n          }\n\n          .dropdown-item:active {\n            color: #343a40;\n            background-color: rgba(0, 0, 0, .03) !important;\n          }\n        </style>\n\n      </div>\n    </div>\n\n  </div>\n</nav>\n<div data-spy=\"scroll\" data-target=\"#navbar\" data-offset=\"0\" class=\"w-100 h-100\">\n  <!-- HEADER -->\n<section id=\"header\" class=\"w-100 h-50 position-relative\" style=\"background-color: rgba(39, 42, 51, 1);\">\n  <div id=\"particles-js\" class=\"position-absolute w-100 h-100\"></div>\n  <div class=\"w-100 h-100 position-absolute\" style=\"top:0; left:0;\">\n    <div class=\"container text-white h-100 d-flex align-items-center justify-content-center flex-column\">\n      <h5 class=\"text-uppercase text-muted\" style=\"letter-spacing: 5px;\">Dokumentasi API</h5>\n      <h1 class=\"text-center\">API Cek Ongkir</h1>\n    </div>\n    <style>\n      #header>.position-absolute>.container>h1 {\n        width: 100%;\n      }\n\n      @media (min-width: 992px) {\n        #header>.position-absolute>.container>h1 {\n          width: 70%;\n        }\n      }\n    </style>\n  </div>\n</section>\n<!-- HEADER END -->\n\n<!-- START -->\n<section id=\"start\">\n  <div class=\"container py-5\">\n    <h4 class=\"text-dark\">API Cek Ongkir</h4>\n    <div class=\"row pt-3\">\n\n      <!-- menu -->\n      <div class=\"col-3\">\n        <div class=\"nav flex-column nav-pills mr-3\" id=\"v-pills-tab\" role=\"tablist\" aria-orientation=\"vertical\">\n\n  <a class=\"navCustom active px-3 py-2 my-1 rounded text-decoration-none text-capitalize\" id=\"v-pills-penjelasan-tab\" data-toggle=\"pill\" href=\"#v-pills-penjelasan\" role=\"tab\" aria-controls=\"v-pills-penjelasan\" aria-selected=\"true\">Penjelasan</a>\n\n  <a class=\"navCustom px-3 py-2 my-1 rounded text-decoration-none text-capitalize\" id=\"v-pills-carapenggunaan-tab\" data-toggle=\"pill\" href=\"#v-pills-carapenggunaan\" role=\"tab\" aria-controls=\"v-pills-carapenggunaan\" aria-selected=\"true\">Cara Penggunaan</a>\n\n  <style>\n    .navCustom {\n      transition: .2s;\n      color: rgba(0, 0, 0, .8);\n      cursor: pointer;\n    }\n\n    .navCustom:hover {\n      color: rgba(0, 0, 0, .9);\n      background-color: rgba(0, 0, 0, .02);\n    }\n\n    .navCustom.active {\n      color: rgba(0, 0, 0, 1);\n      background-color: rgba(0, 0, 0, .04);\n    }\n  </style>\n</div>      </div>\n\n      <!-- content -->\n      <div class=\"col-9\">\n        <div class=\"bg-white shadow-sm py-3 px-4 rounded tab-content\" id=\"v-pills-tabContent\">\n\n  <!-- penjelasan -->\n  <div class=\"tab-pane fade show active\" id=\"v-pills-penjelasan\" role=\"tabpanel\" aria-labelledby=\"v-pills-penjelasan-tab\">\n    <h4>Penjelasan</h4>\n    <hr class=\"bg-dark\">\n    <p class=\"my-1 text-dark d-flex flex-column\">\n      <span>\n        API Cek Tarif adalah api yang berguna untuk mengecek tarif atau ongkos kirim dari berbagai ekspedisi mulai dari jne, pos, anteraja, lion, sap, ide, tiki, sicepat dll.<br><br>\n        Dokumentasi versi terbaru di <a href=\"https://documenter.getpostman.com/view/12963788/TVRg69g4\" target=\"_blank\">POSTMAN</a>\n      </span>\n    </p>\n  </div>\n\n  <!-- cara penggunaan -->\n  <div class=\"tab-pane fade\" id=\"v-pills-carapenggunaan\" role=\"tabpanel\" aria-labelledby=\"v-pills-carapenggunaan-tab\">\n    <h4>Cara Penggunaan</h4>\n    <hr class=\"bg-dark\">\n    <p class=\"my-1 text-dark d-flex flex-column\">\n      <span>\n        <span>\n          Request\n          </span></span></p><pre><code class=\"lang-http rounded hljs\"><span class=\"hljs-keyword\">POST</span> <span class=\"hljs-string\">https://api.binderbyte.com/v1/cost</span> HTTP/1.1\n<span class=\"hljs-attribute\">Content-Type</span>: application/x-www-form-urlencoded</code></pre>\n        \n\n        <span>\n          <table class=\"table table-bordered\">\n            <thead>\n              <tr>\n                <th>Parameter</th>\n                <th>Deskripsi</th>\n              </tr>\n            </thead>\n            <tbody>\n              <tr>\n                <td>api_key</td>\n                <td>untuk mendapatkan api_key, Silahkan <a href=\"https://binderbyte.com/auth/register\">DAFTAR</a></td>\n              </tr>\n              <tr>\n                <td>origin</td>\n                <td>Isi dengan nama kota pengirim contoh cilegon</td>\n              </tr>\n               <tr>\n                <td>destination</td>\n                <td>Isi dengan nama kota penerima contoh jakarta</td>\n              </tr>\n              <tr>\n                <td>courier</td>\n                <td>jne,sicepat,anteraja,lion,sap,pos,ide\n                </td>\n              </tr>\n              <tr>\n                <td>weight</td>\n                <td>Isi dengan berat satuan kg</td>\n              </tr>\n            </tbody>\n          </table>\n        </span>\n\n\n        <span>\n          Response\n          <pre><code class=\"lang-json rounded hljs\">{\n  <span class=\"hljs-attr\">\"code\"</span>: <span class=\"hljs-string\">\"200\"</span>,\n  <span class=\"hljs-attr\">\"message\"</span>: <span class=\"hljs-string\">\"Successfully calculated cost\"</span>,\n  <span class=\"hljs-attr\">\"data\"</span>: {\n    <span class=\"hljs-attr\">\"origin\"</span>: {\n      <span class=\"hljs-attr\">\"id\"</span>: <span class=\"hljs-string\">\"citangkil,cilegon\"</span>,\n      <span class=\"hljs-attr\">\"label\"</span>: <span class=\"hljs-string\">\"CITANGKIL, KOTA CILEGON, BANTEN\"</span>\n    },\n    <span class=\"hljs-attr\">\"destination\"</span>: {\n      <span class=\"hljs-attr\">\"id\"</span>: <span class=\"hljs-string\">\"cibiru,bandung\"</span>,\n      <span class=\"hljs-attr\">\"label\"</span>: <span class=\"hljs-string\">\"CIBIRU, KOTA BANDUNG, JAWA BARAT\"</span>\n    },\n    <span class=\"hljs-attr\">\"weight\"</span>: <span class=\"hljs-number\">1</span>,\n    <span class=\"hljs-attr\">\"results\"</span>: [\n      {\n        <span class=\"hljs-attr\">\"code\"</span>: <span class=\"hljs-string\">\"jne\"</span>,\n        <span class=\"hljs-attr\">\"name\"</span>: <span class=\"hljs-string\">\"JNE Express\"</span>,\n        <span class=\"hljs-attr\">\"costs\"</span>: [\n          {\n            <span class=\"hljs-attr\">\"service\"</span>: <span class=\"hljs-string\">\"REG\"</span>,\n            <span class=\"hljs-attr\">\"description\"</span>: <span class=\"hljs-string\">\"Layanan Reguler\"</span>,\n            <span class=\"hljs-attr\">\"cost\"</span>: <span class=\"hljs-number\">11000</span>,\n            <span class=\"hljs-attr\">\"etd\"</span>: <span class=\"hljs-string\">\"1-2\"</span>\n          },\n          {\n            <span class=\"hljs-attr\">\"service\"</span>: <span class=\"hljs-string\">\"YES\"</span>,\n            <span class=\"hljs-attr\">\"description\"</span>: <span class=\"hljs-string\">\"Yakin Esok Sampai\"</span>,\n            <span class=\"hljs-attr\">\"cost\"</span>: <span class=\"hljs-number\">19000</span>,\n            <span class=\"hljs-attr\">\"etd\"</span>: <span class=\"hljs-string\">\"1-1\"</span>\n          }\n        ]\n      },\n      {\n        <span class=\"hljs-attr\">\"code\"</span>: <span class=\"hljs-string\">\"sicepat\"</span>,\n        <span class=\"hljs-attr\">\"name\"</span>: <span class=\"hljs-string\">\"SiCepat\"</span>,\n        <span class=\"hljs-attr\">\"costs\"</span>: [\n          {\n            <span class=\"hljs-attr\">\"service\"</span>: <span class=\"hljs-string\">\"SIUNT\"</span>,\n            <span class=\"hljs-attr\">\"description\"</span>: <span class=\"hljs-string\">\"SiUntung\"</span>,\n            <span class=\"hljs-attr\">\"cost\"</span>: <span class=\"hljs-number\">11500</span>,\n            <span class=\"hljs-attr\">\"etd\"</span>: <span class=\"hljs-string\">\"1-2\"</span>\n          }\n        ]\n      },\n      {\n        <span class=\"hljs-attr\">\"code\"</span>: <span class=\"hljs-string\">\"ninja\"</span>,\n        <span class=\"hljs-attr\">\"name\"</span>: <span class=\"hljs-string\">\"NINJA\"</span>,\n        <span class=\"hljs-attr\">\"costs\"</span>: [\n          {\n            <span class=\"hljs-attr\">\"service\"</span>: <span class=\"hljs-string\">\"STANDARD\"</span>,\n            <span class=\"hljs-attr\">\"description\"</span>: <span class=\"hljs-string\">\"Standard service\"</span>,\n            <span class=\"hljs-attr\">\"cost\"</span>: <span class=\"hljs-number\">12000</span>,\n            <span class=\"hljs-attr\">\"etd\"</span>: <span class=\"hljs-string\">\"1-3\"</span>\n          }\n        ]\n      }\n    ]\n  }\n}</code></pre>\n        </span>\n\n      \n    <p></p>\n  </div>\n\n</div>      </div>\n    </div>\n  </div>\n</section>\n<!-- START END -->\n  <!-- CONTACT -->\n  <section id=\"contact\" class=\"mt-5 py-lg-5 w-100 bg-light border-bottom\">\n    <div class=\"container py-5\">\n      <div class=\"row d-flex justify-content-between\">\n        <div class=\"my-2 col-lg-3 my-lg-0\">\n          <a href=\"https://binderbyte.com\">\n            <img src=\"/assets/img/logo-primary.svg\" alt=\"Logo BinderByte\" class=\"w-25\">\n          </a>\n          <p class=\"mt-3 text-muted\">\n            BinderByte menyediakan berbagai macam API untuk memenuhi kebutuhan bisnis Anda.\n          </p>\n        </div>\n        <div class=\"my-2 col-lg-7 my-lg-0\">\n          <div class=\"flex-wrap row d-flex\">\n            <div class=\"col-lg-7 d-flex flex-column\">\n              <h4>Kontak Detail</h4>\n              <span class=\"my-2 d-flex flex-column\">\n                <span>Alamat</span>\n                <span class=\"text-muted\">\n                  Link Curug Katimaha RT/RW 001/001, Kota Cilegon, Banten 42419\n                </span>\n              </span>\n              <span class=\"my-2 d-flex flex-column\">\n                <span>WA/Telp</span>\n                <span class=\"text-muted\">\n                  087778899430\n                </span>\n              </span>\n              <span class=\"my-2 d-flex flex-column\">\n                <span>Email</span>\n                <span class=\"text-muted\">\n                  binderbyte@gmail.com\n                </span>\n              </span>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n  <!-- CONTACT END -->\n  <footer class=\"bg-light py-4\">\n    <div class=\"container text-center\">\n      <span>\n        © 2026 Dibuat dengan <i class=\"mdi mdi-heart text-danger\"></i> oleh <a href=\"https://binderbyte.com/\">BinderByte.com</a>\n      </span>\n    </div>\n  </footer>\n</div>\n\n<!-- JS -->\n<script src=\"https://binderbyte.com/assets/highlightjs/highlight.pack.js\"></script>\n<script>\n  hljs.initHighlightingOnLoad();\n</script><style>\n  footer {\n    font-family: 'Sarabun', 'sans-serif';\n    font-weight: 300;\n  }\n\n  footer>div>span {\n    color: rgba(39, 42, 51, .7);\n  }\n\n  footer>div>span>a {\n    transition: .2s;\n    color: rgba(39, 42, 51, .7);\n    font-weight: 500;\n    text-decoration: none;\n  }\n\n  footer>div>span>a:hover {\n    color: rgba(39, 42, 51, 1);\n    text-decoration: underline;\n  }\n</style>\n<script src=\"https://binderbyte.com/assets/bs5/js/popper.min.js\"></script>\n<script src=\"https://binderbyte.com/assets/bs5/js/bootstrap.min.js\"></script>\n<script src=\"https://binderbyte.com/assets/particle/particles.min.js\"></script>\n<script src=\"https://binderbyte.com/assets/waves-effect/js/waves.min.js\"></script>\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/jquery/3.3.1/jquery.min.js\"></script>\n<script>\n  // WAVES\n  Waves.init()\n\n  window.addEventListener('load', function() {\n    if (window.matchMedia(\"(max-width: 991.98px)\").matches) {\n      document.querySelector(\"#navbar .container\").classList.replace('py-3', 'py-1')\n      document.querySelector(\"#navbar\").style.backgroundColor = \"rgba(39, 42, 51, 1)\"\n      document.querySelector(\"#navbar\").classList.add('shadow-sm')\n      document.querySelector(\".nav-link\").classList.add('waves-effect')\n      document.querySelector(\"#navbar\").style.transition = \".2s\"\n      document.querySelector(\"#navbar .container\").style.transition = \".2s\"\n    } else {\n      window.onscroll = function() {\n        navbarScroll()\n      };\n    }\n  });\n\n  // NAVBAR SCROLL\n  function navbarScroll() {\n    if (document.body.scrollTop > 80 || document.documentElement.scrollTop > 80) {\n      // SCROLL\n      document.querySelector(\"#navbar .container\").classList.replace('py-3', 'py-1')\n      document.querySelector(\"#navbar\").style.backgroundColor = \"rgba(39, 42, 51, 1)\"\n      document.querySelector(\"#navbar\").classList.add('shadow-sm')\n      document.querySelector(\"#navbar\").style.transition = \".2s\"\n      document.querySelector(\"#navbar .container\").style.transition = \".2s\"\n    } else {\n      // !SCROLL\n      document.querySelector(\"#navbar .container\").classList.replace('py-1', 'py-3')\n      document.querySelector(\"#navbar\").style.backgroundColor = \"transparent\"\n      document.querySelector(\"#navbar\").classList.remove('shadow-sm')\n      document.querySelector(\"#navbar\").style.transition = \".2s\"\n      document.querySelector(\"#navbar .container\").style.transition = \".2s\"\n    }\n  }\n\n  // PARTICLE JS\n  particlesJS.load('particles-js', 'https://binderbyte.com/assets/particle/particlesjs-config.json', function() {\n    console.log('callback - particles.js config loaded');\n  });\n\n  // NAVBAR REFRESH PAGE\n  if (document.body.scrollTop > 80 || document.documentElement.scrollTop > 80) {\n    document.querySelector(\"#navbar .container\").classList.replace('py-3', 'py-1')\n    document.querySelector(\"#navbar\").style.backgroundColor = \"rgba(39, 42, 51, 1)\"\n    document.querySelector(\"#navbar\").classList.add('shadow-sm')\n    document.querySelector(\"#navbar\").style.transition = \".2s\"\n    document.querySelector(\"#navbar .container\").style.transition = \".2s\"\n  }\n\n  //WHATSAPP\n  (function($) {\n    var wa_time_out, wa_time_in;\n    $(document).ready(function() {\n      $(\".wa__btn_popup\").on(\"click\", function() {\n        if ($(\".wa__popup_chat_box\").hasClass(\"wa__active\")) {\n          $(\".wa__popup_chat_box\").removeClass(\"wa__active\");\n          $(\".wa__btn_popup\").removeClass(\"wa__active\");\n          clearTimeout(wa_time_in);\n          if ($(\".wa__popup_chat_box\").hasClass(\"wa__lauch\")) {\n            wa_time_out = setTimeout(function() {\n              $(\".wa__popup_chat_box\").removeClass(\"wa__pending\");\n              $(\".wa__popup_chat_box\").removeClass(\"wa__lauch\");\n            }, 400);\n          }\n        } else {\n          $(\".wa__popup_chat_box\").addClass(\"wa__pending\");\n          $(\".wa__popup_chat_box\").addClass(\"wa__active\");\n          $(\".wa__btn_popup\").addClass(\"wa__active\");\n          clearTimeout(wa_time_out);\n          if (!$(\".wa__popup_chat_box\").hasClass(\"wa__lauch\")) {\n            wa_time_in = setTimeout(function() {\n              $(\".wa__popup_chat_box\").addClass(\"wa__lauch\");\n            }, 100);\n          }\n        }\n      });\n\n      function setCookie(cname, cvalue, exdays) {\n        var d = new Date();\n        d.setTime(d.getTime() + exdays * 24 * 60 * 60 * 1000);\n        var expires = \"expires=\" + d.toUTCString();\n        document.cookie = cname + \"=\" + cvalue + \";\" + expires + \";path=/\";\n      }\n\n      function getCookie(cname) {\n        var name = cname + \"=\";\n        var ca = document.cookie.split(\";\");\n        for (var i = 0; i < ca.length; i++) {\n          var c = ca[i];\n          while (c.charAt(0) == \" \") {\n            c = c.substring(1);\n          }\n          if (c.indexOf(name) == 0) {\n            return c.substring(name.length, c.length);\n          }\n        }\n        return \"\";\n      }\n\n      $(\"#nta-wa-gdpr\").change(function() {\n        if (this.checked) {\n          setCookie(\"nta-wa-gdpr\", \"accept\", 30);\n          if (getCookie(\"nta-wa-gdpr\") != \"\") {\n            $('.nta-wa-gdpr').hide(500);\n            $('.wa__popup_content_item').each(function(){\n              $(this).removeClass('pointer-disable');\n              $('.wa__popup_content_list').off('click');\n            })\n          }\n        }\n      });\n\n      if (getCookie(\"nta-wa-gdpr\") != \"\") {\n        $('.wa__popup_content_list').off('click');\n      } else{\n        $('.wa__popup_content_list').click(function(){\n          $('.nta-wa-gdpr').delay(500).css({\"background\" : \"red\", \"color\" : \"#fff\"});\n        });\n      }\n    });\n  })(jQuery);\n</script>\n<!-- Announcement Modal -->\n<div class=\"modal fade\" id=\"announcementModal\" tabindex=\"-1\" aria-labelledby=\"announcementModalLabel\" aria-hidden=\"true\">\n  <div class=\"modal-dialog modal-dialog-centered\">\n    <div class=\"modal-content overflow-hidden border-0 shadow-lg\" style=\"border-radius: 20px; background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(10px);\">\n      <div class=\"modal-header border-0 p-4 d-flex flex-column align-items-center text-center\" style=\"background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);\">\n        <div class=\"bg-white rounded-circle p-3 mb-3 shadow-sm d-flex align-items-center justify-content-center\" style=\"width: 70px; height: 70px;\">\n          <i class=\"mdi mdi-rocket-launch text-primary\" style=\"font-size: 30px;\"></i>\n        </div>\n        <h4 class=\"modal-title font-weight-bold text-white\" id=\"announcementModalLabel\">Kabar Gembira!</h4>\n      </div>\n      <div class=\"modal-body p-4 text-center\">\n        <p class=\"lead text-dark font-weight-medium\">Kini API Cek Ongkir sudah tersedia di BinderByte!</p>\n        <p class=\"text-muted\">Nikmati kemudahan integrasi pengecekan tarif pengiriman secara otomatis untuk berbagai ekspedisi dalam satu API.</p>\n        \n        <div class=\"p-3 bg-light rounded-lg border mb-4\">\n            <small class=\"text-muted d-block mb-1\">Cek Dokumentasi Postman:</small>\n            <a href=\"https://documenter.getpostman.com/view/12963788/TVRg69g4\" target=\"_blank\" class=\"text-primary font-weight-bold break-all\">\n                https://documenter.getpostman.com/view/12963788/TVRg69g4\n            </a>\n        </div>\n        \n        <div class=\"d-grid gap-2 d-md-block\">\n          <a href=\"https://documenter.getpostman.com/view/12963788/TVRg69g4\" target=\"_blank\" class=\"btn btn-primary px-5 py-2 shadow-sm\" style=\"border-radius: 10px; font-weight: 600;\">Lihat Dokumentasi</a>\n          <button type=\"button\" class=\"btn btn-link text-muted mt-2 d-block mx-auto\" data-bs-dismiss=\"modal\" data-dismiss=\"modal\" onclick=\"try { bootstrap.Modal.getInstance(document.getElementById('announcementModal')).hide(); } catch(e) { $('#announcementModal').modal('hide'); }\">Nanti saja</button>\n        </div>\n      </div>\n    </div>\n  </div>\n</div>\n\n<style>\n  #announcementModal .modal-content {\n    animation: modalPop 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n  }\n  \n  @keyframes modalPop {\n    from { opacity: 0; transform: scale(0.8); }\n    to { opacity: 1; transform: scale(1); }\n  }\n\n  .break-all {\n    word-break: break-all;\n  }\n  \n  #announcementModal .btn-primary {\n    transition: all 0.3s ease;\n  }\n  \n  #announcementModal .btn-primary:hover {\n    transform: translateY(-2px);\n    box-shadow: 0 5px 15px rgba(99, 102, 241, 0.4) !important;\n  }\n</style>\n\n<script>\n  // Robust popup trigger for footer\n  (function() {\n    function initAnnouncementModal() {\n      if (typeof bootstrap !== 'undefined' && document.getElementById('announcementModal')) {\n        setTimeout(function() {\n          var myModal = new bootstrap.Modal(document.getElementById('announcementModal'));\n          myModal.show();\n        }, 500);\n      } else {\n        // Retry if bootstrap not ready\n        setTimeout(initAnnouncementModal, 200);\n      }\n    }\n\n    // Only show on homepage to avoid being annoying\n    if (window.location.pathname === '/' || window.location.pathname === '') {\n        window.addEventListener('load', initAnnouncementModal);\n    }\n  })();\n</script>\n\n<script defer=\"\" src=\"https://static.cloudflareinsights.com/beacon.min.js/v833ccba57c9e4d2798f2e76cebdd09a11778172276447\" integrity=\"sha512-57MDmcccJXYtNnH+ZiBwzC4jb2rvgVCEokYN+L/nLlmO8rfYT/gIpW2A569iJ/3b+0UEasghjuZH/ma3wIs/EQ==\" data-cf-beacon=\"{&quot;version&quot;:&quot;2024.11.0&quot;,&quot;token&quot;:&quot;e4767fe0a18c42f897c278d5e3e605a9&quot;,&quot;r&quot;:1,&quot;server_timing&quot;:{&quot;name&quot;:{&quot;cfCacheStatus&quot;:true,&quot;cfEdge&quot;:true,&quot;cfExtPri&quot;:true,&quot;cfL4&quot;:true,&quot;cfOrigin&quot;:true,&quot;cfSpeedBrain&quot;:true},&quot;location_startswith&quot;:null}}\" crossorigin=\"anonymous\"></script>\n\n\n</body></html>",
