    "html": "<html lang=\"en\" class=\"w-100 h-100\"><head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <link rel=\"shortcut icon\" href=\"/favicon.ico\" type=\"image/x-icon\">\n\n  <title>BinderByte - Kumpulan API untuk Developers</title>\n  <meta name=\"description\" content=\"BinderByte adalah penyedia kumpulan API dari berbagai sumber terbuka untuk memudahkan developers mulai dari api cek resi, api cek ongkir tarif, api wiliyah indonesia dan lainnya.\">\n  <meta name=\"robots\" content=\"index, follow\">\n  <meta name=\"author\" content=\"Aan Aliudin\">\n  <link rel=\"canonical\" href=\"https://binderbyte.com/\">\n\n  <meta property=\"og:title\" content=\"BinderByte - Kumpulan API untuk Developers\">\n  <meta property=\"og:description\" content=\"BinderByte adalah penyedia kumpulan API dari berbagai sumber terbuka untuk memudahkan developers mulai dari api cek resi, api cek ongkir tarif, api wiliyah indonesia dan lainnya.\">\n  <meta property=\"og:url\" content=\"https://binderbyte.com\">\n\n  <link href=\"https://fonts.googleapis.com/css2?family=Sarabun:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800&amp;display=swap\" rel=\"stylesheet\">\n  <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/MaterialDesign-Webfont/5.5.55/css/materialdesignicons.min.css\">\n  <link rel=\"stylesheet\" href=\"https://binderbyte.com/assets/font-awesome/css/all.min.css\">\n  <link rel=\"stylesheet\" href=\"https://binderbyte.com/assets/waves-effect/css/waves.min.css\">\n  <link rel=\"stylesheet\" href=\"https://binderbyte.com/assets/bs5/css/bootstrap.min.css\">\n  <link rel=\"stylesheet\" href=\"https://binderbyte.com/assets/templates/css/whatsapp.css\">\n  <style>\n    html,\n    body {\n      scroll-behavior: smooth;\n      position: relative !important;\n    }\n\n    ::-webkit-scrollbar {\n      width: 0 !important;\n    }\n\n    ::selection {\n      background: #000;\n      color: #fff;\n    }\n\n    .btn:focus {\n      outline: none !important;\n      box-shadow: none !important;\n    }\n  </style>\n\n</head>\n\n<body class=\"w-100 h-100 modal-open\"><!-- NAVBAR -->\n<nav id=\"navbar\" class=\"navbar navbar-expand-lg navbar-dark fixed-top\" style=\"background-color: transparent;\">\n  <div class=\"container py-3\">\n\n    <a class=\"navbar-brand\" href=\"https://binderbyte.com/\">\n      <img src=\"/assets/img/long-logo.svg\" class=\"d-none d-lg-block\" height=\"30\" loading=\"lazy\">\n      <img src=\"/assets/img/logo.svg\" class=\"d-block d-lg-none\" height=\"30\" loading=\"lazy\">\n    </a>\n\n    <button class=\"navbar-toggler\" type=\"button\" data-toggle=\"collapse\" data-target=\"#navbarNavAltMarkup\" aria-controls=\"navbarNavAltMarkup\" aria-expanded=\"false\" aria-label=\"Toggle navigation\">\n      <span class=\"navbar-toggler-icon\"></span>\n    </button>\n    <div class=\"mt-3 mt-lg-0 collapse navbar-collapse\" id=\"navbarNavAltMarkup\">\n      <div class=\"ml-auto navbar-nav nav-pills\">\n          <a class=\"my-1 text-center nav-link my-lg-0 mx-lg-2 active\" href=\"https://binderbyte.com/\">Home</a>\n          <a class=\"my-1 text-center nav-link my-lg-0 mx-lg-2\" href=\"#product\">Product</a>\n          <a class=\"my-1 text-center nav-link my-lg-0 mx-lg-2\" href=\"#features\">Feature</a>\n          <a class=\"my-1 text-center nav-link my-lg-0 mx-lg-2\" href=\"#faq\">FAQ</a>\n        <li class=\"nav-item dropdown my-1 text-center my-lg-0 mx-lg-2\">\n          <a class=\"nav-link\" href=\"https://binderbyte.com/syarat-dan-ketentuan.html\" target=\"_blank\">Terms &amp; Conditions\n          </a>\n        </li>\n        <li class=\"nav-item dropdown my-1 text-center my-lg-0 mx-lg-2\">\n          <a class=\"nav-link\" href=\"https://documenter.getpostman.com/view/12963788/TVRg69g4\" target=\"_blank\">\n            Documentation\n          </a>\n        </li>\n\n        <!-- TOMBOL MASUK -->\n                  <a href=\"/auth/login\" id=\"btnNavCTA\" class=\"my-1 text-center nav-link my-lg-0 waves-effect px-lg-5 ml-lg-5 d-block d-lg-inline\">Login</a>\n          <style>\n            #btnNavCTA {\n              color: rgba(39, 42, 51, 1);\n              background: white;\n              border: 1px solid white;\n              transition: .2s;\n            }\n          </style>\n        \n        <!-- DASHBOARD LINK -->\n        \n        <style>\n          .nav-link.active {\n            color: rgba(255, 255, 255, 1);\n            background-color: transparent !important;\n          }\n\n          .dropdown-item:active {\n            color: #343a40;\n            background-color: rgba(0, 0, 0, .03) !important;\n          }\n        </style>\n\n      </div>\n    </div>\n\n  </div>\n</nav>\n<div data-spy=\"scroll\" data-target=\"#navbar\" data-offset=\"0\" class=\"w-100 h-100\">\n  <!-- HEADER -->\n<section id=\"header\" class=\"w-100 h-100 position-relative\" style=\"background-color: rgba(39, 42, 51, 1);\">\n  <div id=\"particles-js\" class=\"position-absolute w-100 h-100\"><canvas class=\"particles-js-canvas-el\" width=\"1280\" height=\"1280\" style=\"width: 100%; height: 100%;\"></canvas></div>\n  <div class=\"w-100 h-100 position-absolute\" style=\"top:0; left:0;\">\n    <div class=\"container text-white h-100 d-flex align-items-center justify-content-center flex-column\">\n      <h5 class=\"text-uppercase text-muted\" style=\"letter-spacing: 5px;\">Integrasi API</h5>\n      <h1 class=\"text-center\">Ayo Hubungkan Aplikasi Anda Dengan BinderByte</h1>\n      <h6 class=\"my-4 text-center lead text-light\">BinderByte menyediakan berbagai macam API untuk memenuhi kebutuhan bisnis Anda.</h6>\n\n      <!-- DAFTAR BUTTON -->\n              <a href=\"/auth/register\" id=\"ctaRegister\" class=\"px-5 py-3 mt-3 waves-effect btn btn-lg\">Daftar Sekarang</a>\n          </div>\n    <style>\n      #ctaRegister {\n        border: 1px solid white;\n        background: white;\n        color: rgba(39, 42, 51, 1);\n      }\n\n      #header>.position-absolute>.container>h1,\n      #header>.position-absolute>.container>h6 {\n        width: 100%;\n      }\n\n      @media (min-width: 992px) {\n        #header>.position-absolute>.container>h1 {\n          width: 70%;\n        }\n\n        #header>.position-absolute>.container>h6 {\n          width: 40%;\n        }\n      }\n    </style>\n  </div>\n</section>\n<!-- HEADER END -->\n\n<!-- PRODUCT -->\n<section id=\"product\" class=\"py-5 w-100\">\n  <div class=\"container py-2 mt-5\">\n    <!-- title -->\n    <div class=\"text-center\">\n      <h1 class=\"display-4\">Produk API</h1>\n      <p class=\"text-muted\">Daftar produk yang tersedia di BinderByte</p>\n    </div>\n\n    <!-- products -->\n    <div class=\"flex-wrap mt-5 row d-flex\">\n              <div class=\"my-3 col-lg-4 d-flex flex-column my-lg-3\">\n          <div class=\"text-center card h-100\">\n            <h6 class=\"card-header\">\n              API Wilayah Indonesia            </h6>\n            <div class=\"card-body d-flex flex-column justify-content-between\">\n              <p class=\"card-text flex-grow-1\">\n                API Wilayah Administrasi Indonesia adalah api data wilayah seluruh indonesia mulai dari provinsi, kabupaten, kecamatan dan kelurahan. Sumber dari bps.go.id              </p>\n              <a href=\"http://docs.binderbyte.com/api/wilayah\" class=\"btn btn-primary\">Dokumentasi</a>\n            </div>\n          </div>\n        </div>\n              <div class=\"my-3 col-lg-4 d-flex flex-column my-lg-3\">\n          <div class=\"text-center card h-100\">\n            <h6 class=\"card-header\">\n              API Cek Resi            </h6>\n            <div class=\"card-body d-flex flex-column justify-content-between\">\n              <p class=\"card-text flex-grow-1\">\n                API Cek Resi adalah api yang berguna untuk melacak resi secara otomatis mulai dari jne, pos, jnt, wahana, tiki, sicepat dll.              </p>\n              <a href=\"http://docs.binderbyte.com/api/cek-resi\" class=\"btn btn-primary\">Dokumentasi</a>\n            </div>\n          </div>\n        </div>\n              <div class=\"my-3 col-lg-4 d-flex flex-column my-lg-3\">\n          <div class=\"text-center card h-100\">\n            <h6 class=\"card-header\">\n              API Cek Ongkir            </h6>\n            <div class=\"card-body d-flex flex-column justify-content-between\">\n              <p class=\"card-text flex-grow-1\">\n                API Cek Ongkir adalah API yang digunakan untuk menghitung biaya pengiriman dari berbagai jasa ekspedisi seperti JNE, POS, J&amp;T, Wahana, TIKI, SiCepat, dan lainnya.              </p>\n              <a href=\"http://docs.binderbyte.com/api/cek-tarif\" class=\"btn btn-primary\">Dokumentasi</a>\n            </div>\n          </div>\n        </div>\n          </div>\n  </div>\n</section>\n<!-- PRODUCT END -->\n\n<!-- FEATURES -->\n<section id=\"features\" class=\"py-lg-5 w-100\">\n  <div class=\"container py-1 mt-5 py-lg-2\">\n    <div class=\"flex-wrap row d-flex align-items-center\">\n      <div class=\"col-lg-5 d-flex flex-column\">\n        <h1 class=\"text-center display-4 text-lg-left\">Kenapa BinderByte?</h1>\n      </div>\n      <div class=\"col-lg-7 d-flex flex-column\">\n        <div class=\"flex-wrap row d-flex\">\n\n          <div class=\"my-2 col-lg-4 d-flex flex-column\">\n            <div class=\"card h-100\">\n              <div class=\"card-body d-flex align-items-center align-items-lg-start\">\n                <h4 class=\"px-0 py-0 mx-0 my-0\">Data Akurat</h4>\n              </div>\n            </div>\n          </div>\n\n          <div class=\"my-2 col-lg-4 d-flex flex-column\">\n            <div class=\"card h-100\">\n              <div class=\"card-body d-flex align-items-center align-items-lg-start\">\n                <h4 class=\"px-0 py-0 mx-0 my-0\">Harga Terjangkau</h4>\n              </div>\n            </div>\n          </div>\n\n          <div class=\"my-2 col-lg-4 d-flex flex-column\">\n            <div class=\"card h-100\">\n              <div class=\"card-body d-flex align-items-center align-items-lg-start\">\n                <h4 class=\"px-0 py-0 mx-0 my-0\">Banyak Pilihan API</h4>\n              </div>\n            </div>\n          </div>\n\n          <div class=\"my-2 col-lg-4 d-flex flex-column\">\n            <div class=\"card h-100\">\n              <div class=\"card-body d-flex align-items-center align-items-lg-start\">\n                <h4 class=\"px-0 py-0 mx-0 my-0\">Integrasi Mudah</h4>\n              </div>\n            </div>\n          </div>\n\n          <div class=\"my-2 col-lg-4 d-flex flex-column\">\n            <div class=\"card h-100\">\n              <div class=\"card-body d-flex align-items-center align-items-lg-start\">\n                <h4 class=\"px-0 py-0 mx-0 my-0\">REST API JSON</h4>\n              </div>\n            </div>\n          </div>\n\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n<!-- FEATURES END -->\n\n<!-- FAQ -->\n<section id=\"faq\" class=\"py-lg-5 w-100\">\n  <div class=\"container py-1 mt-5 py-lg-2\">\n<h2 class=\"display-6\">FAQ - Tanya Jawab</h2>\n<div class=\"accordion\" id=\"accordionExample\">\n  <div class=\"card\">\n    <div class=\"card-header\" id=\"headingOne\">\n      <h2 class=\"mb-0\">\n        <button class=\"btn btn-link\" type=\"button\" data-toggle=\"collapse\" data-target=\"#collapseOne\" aria-expanded=\"true\" aria-controls=\"collapseOne\">\n          Apakah Layanan API dari binderbyte Gratis ?\n        </button>\n      </h2>\n    </div>\n\n    <div id=\"collapseOne\" class=\"collapse show\" aria-labelledby=\"headingOne\" data-parent=\"#accordionExample\">\n      <div class=\"card-body\">\n        Tidak gratis alias berbayar. Semua layanan API yang tersedia di binderbyte, bisa di gunakan secara trial dengan batasan tertentu sesuai paket yang dipilih.\n      </div>\n    </div>\n  </div>\n  \n  <div class=\"card\">\n    <div class=\"card-header\" id=\"headingThree\">\n      <h2 class=\"mb-0\">\n        <button class=\"btn btn-link collapsed\" type=\"button\" data-toggle=\"collapse\" data-target=\"#collapseThree\" aria-expanded=\"false\" aria-controls=\"collapseThree\">\n          Apakah setiap request/hit API data yang sama akan tetap dihitung?\n        </button>\n      </h2>\n    </div>\n    <div id=\"collapseThree\" class=\"collapse\" aria-labelledby=\"headingThree\" data-parent=\"#accordionExample\">\n      <div class=\"card-body\">\n        Setiap request/hit data yang sama akan tetap dihitung 1 hit selama response dari API tersebut sukses.\n      </div>\n    </div>\n  </div>\n  <div class=\"card\">\n    <div class=\"card-header\" id=\"headingFour\">\n      <h2 class=\"mb-0\">\n        <button class=\"btn btn-link collapsed\" type=\"button\" data-toggle=\"collapse\" data-target=\"#collapseFour\" aria-expanded=\"false\" aria-controls=\"collapseFour\">\n         Dimana saya bisa melihat daftar harga?\n        </button>\n      </h2>\n    </div>\n    <div id=\"collapseFour\" class=\"collapse\" aria-labelledby=\"headingFour\" data-parent=\"#accordionExample\">\n      <div class=\"card-body\">\n        Harga bisa dilihat di halaman dashboard setelah melakukan pendaftaran dan login.\n      </div>\n    </div>\n  </div>\n \n  <div class=\"card\">\n    <div class=\"card-header\" id=\"headingSix\">\n      <h2 class=\"mb-0\">\n        <button class=\"btn btn-link collapsed\" type=\"button\" data-toggle=\"collapse\" data-target=\"#collapseSix\" aria-expanded=\"false\" aria-controls=\"collapseSix\">\n         Apakah saya dapat mengupdate API Key ?\n        </button>\n      </h2>\n    </div>\n    <div id=\"collapseSix\" class=\"collapse\" aria-labelledby=\"headingSix\" data-parent=\"#accordionExample\">\n      <div class=\"card-body\">\n        Bisa, Anda bisa mengupdate/mengubah API Key secara berkala melalui dashboard binderbyte dengan cara klik foto profile Anda lalu klik profile &gt; API Key\n      </div>\n    </div>\n  </div>\n</div></div>\n</section>\n<!-- END FAQ -->\n  <!-- CONTACT -->\n  <section id=\"contact\" class=\"mt-5 py-lg-5 w-100 bg-light border-bottom\">\n    <div class=\"container py-5\">\n      <div class=\"row d-flex justify-content-between\">\n        <div class=\"my-2 col-lg-3 my-lg-0\">\n          <a href=\"https://binderbyte.com\">\n            <img src=\"/assets/img/logo-primary.svg\" alt=\"Logo BinderByte\" class=\"w-25\">\n          </a>\n          <p class=\"mt-3 text-muted\">\n            BinderByte menyediakan berbagai macam API untuk memenuhi kebutuhan bisnis Anda.\n          </p>\n        </div>\n        <div class=\"my-2 col-lg-7 my-lg-0\">\n          <div class=\"flex-wrap row d-flex\">\n            <div class=\"col-lg-7 d-flex flex-column\">\n              <h4>Kontak Detail</h4>\n              <span class=\"my-2 d-flex flex-column\">\n                <span>Alamat</span>\n                <span class=\"text-muted\">\n                    Kota Cilegon\n                </span>\n              </span>\n              <span class=\"my-2 d-flex flex-column\">\n                <span>Email</span>\n                <span class=\"text-muted\">\n                  binderbyte@gmail.com\n                </span>\n              </span>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- Widget WA -->\n  <div class=\"wa__btn_popup\">\n  <div class=\"wa__btn_popup_txt\">Butuh bantuan? <strong>Ayo chat dengan kami!</strong></div>\n  <div class=\"wa__btn_popup_icon\"></div>\n  </div>\n\n  <div class=\"wa__popup_chat_box wa__pending wa__lauch\">\n\n  <div class=\"wa__popup_heading\">\n  <div class=\"wa__popup_title\">Butuh bantuan? Ayo chat dengan kami!</div>\n  <div class=\"wa__popup_intro\"></div>\n  </div>\n\n  <div class=\"wa__popup_content wa__popup_content_left\">\n  <div class=\"wa__popup_notice\">Kami akan membalas pesan Anda dalam beberapa saat</div>\n\n  <div class=\"wa__popup_content_list\">\n\n  <div class=\"wa__popup_content_item\">\n  <a target=\"_blank\" href=\"https://wa.me/6287778899430?text=Haloo *BinderByte*, Saya ingin bertanya mengenai layanan API binderbyte?\" class=\"wa__stt wa__stt_online\">\n  <div class=\"wa__popup_avatar\">\n  <div class=\"wa__cs_img_wrap\" style=\"background: url(/assets/img/team/aan.jpg) center center no-repeat; background-size: cover;\"></div></div><div class=\"wa__popup_txt\">\n  <div class=\"wa__member_name\">Aan Aliudin</div><div class=\"wa__member_duty\">Support Layanan</div></div></a></div>\n\n  <!-- <div class=\"wa__popup_content_item\">\n  <a target=\"_blank\" href=\"https://web.whatsapp.com/send?phone=&amp;text=Haloo *BinderByte*, Saya ingin bertanya mengenai layanan API binderbyte?\" class=\"wa__stt wa__stt_online\">\n  <div class=\"wa__popup_avatar\">\n  <div class=\"wa__cs_img_wrap\" style=\"background: url(/assets/img/team/nanang.jpg) center center no-repeat; background-size: cover;\"></div></div><div class=\"wa__popup_txt\">\n  <div class=\"wa__member_name\">Nanang Kardiyanto</div><div class=\"wa__member_duty\">Support API Whatsapp</div></div></a></div> -->\n\n  </div>\n\n  </div></div>\n\n  <!-- CONTACT END -->\n  <footer class=\"bg-light py-4\">\n    <div class=\"container text-center\">\n      <span>\n        © 2026 Dibuat dengan <i class=\"mdi mdi-heart text-danger\"></i> oleh <a href=\"https://binderbyte.com/\">BinderByte.com</a>\n      </span>\n    </div>\n  </footer>\n</div><style>\n  footer {\n    font-family: 'Sarabun', 'sans-serif';\n    font-weight: 300;\n  }\n\n  footer>div>span {\n    color: rgba(39, 42, 51, .7);\n  }\n\n  footer>div>span>a {\n    transition: .2s;\n    color: rgba(39, 42, 51, .7);\n    font-weight: 500;\n    text-decoration: none;\n  }\n\n  footer>div>span>a:hover {\n    color: rgba(39, 42, 51, 1);\n    text-decoration: underline;\n  }\n</style>\n<script src=\"https://binderbyte.com/assets/bs5/js/popper.min.js\"></script>\n<script src=\"https://binderbyte.com/assets/bs5/js/bootstrap.min.js\"></script>\n<script src=\"https://binderbyte.com/assets/particle/particles.min.js\"></script>\n<script src=\"https://binderbyte.com/assets/waves-effect/js/waves.min.js\"></script>\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/jquery/3.3.1/jquery.min.js\"></script>\n<script>\n  // WAVES\n  Waves.init()\n\n  window.addEventListener('load', function() {\n    if (window.matchMedia(\"(max-width: 991.98px)\").matches) {\n      document.querySelector(\"#navbar .container\").classList.replace('py-3', 'py-1')\n      document.querySelector(\"#navbar\").style.backgroundColor = \"rgba(39, 42, 51, 1)\"\n      document.querySelector(\"#navbar\").classList.add('shadow-sm')\n      document.querySelector(\".nav-link\").classList.add('waves-effect')\n      document.querySelector(\"#navbar\").style.transition = \".2s\"\n      document.querySelector(\"#navbar .container\").style.transition = \".2s\"\n    } else {\n      window.onscroll = function() {\n        navbarScroll()\n      };\n    }\n  });\n\n  // NAVBAR SCROLL\n  function navbarScroll() {\n    if (document.body.scrollTop > 80 || document.documentElement.scrollTop > 80) {\n      // SCROLL\n      document.querySelector(\"#navbar .container\").classList.replace('py-3', 'py-1')\n      document.querySelector(\"#navbar\").style.backgroundColor = \"rgba(39, 42, 51, 1)\"\n      document.querySelector(\"#navbar\").classList.add('shadow-sm')\n      document.querySelector(\"#navbar\").style.transition = \".2s\"\n      document.querySelector(\"#navbar .container\").style.transition = \".2s\"\n    } else {\n      // !SCROLL\n      document.querySelector(\"#navbar .container\").classList.replace('py-1', 'py-3')\n      document.querySelector(\"#navbar\").style.backgroundColor = \"transparent\"\n      document.querySelector(\"#navbar\").classList.remove('shadow-sm')\n      document.querySelector(\"#navbar\").style.transition = \".2s\"\n      document.querySelector(\"#navbar .container\").style.transition = \".2s\"\n    }\n  }\n\n  // PARTICLE JS\n  particlesJS.load('particles-js', 'https://binderbyte.com/assets/particle/particlesjs-config.json', function() {\n    console.log('callback - particles.js config loaded');\n  });\n\n  // NAVBAR REFRESH PAGE\n  if (document.body.scrollTop > 80 || document.documentElement.scrollTop > 80) {\n    document.querySelector(\"#navbar .container\").classList.replace('py-3', 'py-1')\n    document.querySelector(\"#navbar\").style.backgroundColor = \"rgba(39, 42, 51, 1)\"\n    document.querySelector(\"#navbar\").classList.add('shadow-sm')\n    document.querySelector(\"#navbar\").style.transition = \".2s\"\n    document.querySelector(\"#navbar .container\").style.transition = \".2s\"\n  }\n\n  //WHATSAPP\n  (function($) {\n    var wa_time_out, wa_time_in;\n    $(document).ready(function() {\n      $(\".wa__btn_popup\").on(\"click\", function() {\n        if ($(\".wa__popup_chat_box\").hasClass(\"wa__active\")) {\n          $(\".wa__popup_chat_box\").removeClass(\"wa__active\");\n          $(\".wa__btn_popup\").removeClass(\"wa__active\");\n          clearTimeout(wa_time_in);\n          if ($(\".wa__popup_chat_box\").hasClass(\"wa__lauch\")) {\n            wa_time_out = setTimeout(function() {\n              $(\".wa__popup_chat_box\").removeClass(\"wa__pending\");\n              $(\".wa__popup_chat_box\").removeClass(\"wa__lauch\");\n            }, 400);\n          }\n        } else {\n          $(\".wa__popup_chat_box\").addClass(\"wa__pending\");\n          $(\".wa__popup_chat_box\").addClass(\"wa__active\");\n          $(\".wa__btn_popup\").addClass(\"wa__active\");\n          clearTimeout(wa_time_out);\n          if (!$(\".wa__popup_chat_box\").hasClass(\"wa__lauch\")) {\n            wa_time_in = setTimeout(function() {\n              $(\".wa__popup_chat_box\").addClass(\"wa__lauch\");\n            }, 100);\n          }\n        }\n      });\n\n      function setCookie(cname, cvalue, exdays) {\n        var d = new Date();\n        d.setTime(d.getTime() + exdays * 24 * 60 * 60 * 1000);\n        var expires = \"expires=\" + d.toUTCString();\n        document.cookie = cname + \"=\" + cvalue + \";\" + expires + \";path=/\";\n      }\n\n      function getCookie(cname) {\n        var name = cname + \"=\";\n        var ca = document.cookie.split(\";\");\n        for (var i = 0; i < ca.length; i++) {\n          var c = ca[i];\n          while (c.charAt(0) == \" \") {\n            c = c.substring(1);\n          }\n          if (c.indexOf(name) == 0) {\n            return c.substring(name.length, c.length);\n          }\n        }\n        return \"\";\n      }\n\n      $(\"#nta-wa-gdpr\").change(function() {\n        if (this.checked) {\n          setCookie(\"nta-wa-gdpr\", \"accept\", 30);\n          if (getCookie(\"nta-wa-gdpr\") != \"\") {\n            $('.nta-wa-gdpr').hide(500);\n            $('.wa__popup_content_item').each(function(){\n              $(this).removeClass('pointer-disable');\n              $('.wa__popup_content_list').off('click');\n            })\n          }\n        }\n      });\n\n      if (getCookie(\"nta-wa-gdpr\") != \"\") {\n        $('.wa__popup_content_list').off('click');\n      } else{\n        $('.wa__popup_content_list').click(function(){\n          $('.nta-wa-gdpr').delay(500).css({\"background\" : \"red\", \"color\" : \"#fff\"});\n        });\n      }\n    });\n  })(jQuery);\n</script>\n<!-- Announcement Modal -->\n<div class=\"modal fade show\" id=\"announcementModal\" tabindex=\"-1\" aria-labelledby=\"announcementModalLabel\" aria-modal=\"true\" role=\"dialog\" style=\"display: block;\">\n  <div class=\"modal-dialog modal-dialog-centered\">\n    <div class=\"modal-content overflow-hidden border-0 shadow-lg\" style=\"border-radius: 20px; background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(10px);\">\n      <div class=\"modal-header border-0 p-4 d-flex flex-column align-items-center text-center\" style=\"background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);\">\n        <div class=\"bg-white rounded-circle p-3 mb-3 shadow-sm d-flex align-items-center justify-content-center\" style=\"width: 70px; height: 70px;\">\n          <i class=\"mdi mdi-rocket-launch text-primary\" style=\"font-size: 30px;\"></i>\n        </div>\n        <h4 class=\"modal-title font-weight-bold text-white\" id=\"announcementModalLabel\">Kabar Gembira!</h4>\n      </div>\n      <div class=\"modal-body p-4 text-center\">\n        <p class=\"lead text-dark font-weight-medium\">Kini API Cek Ongkir sudah tersedia di BinderByte!</p>\n        <p class=\"text-muted\">Nikmati kemudahan integrasi pengecekan tarif pengiriman secara otomatis untuk berbagai ekspedisi dalam satu API.</p>\n        \n        <div class=\"p-3 bg-light rounded-lg border mb-4\">\n            <small class=\"text-muted d-block mb-1\">Cek Dokumentasi Postman:</small>\n            <a href=\"https://documenter.getpostman.com/view/12963788/TVRg69g4\" target=\"_blank\" class=\"text-primary font-weight-bold break-all\">\n                https://documenter.getpostman.com/view/12963788/TVRg69g4\n            </a>\n        </div>\n        \n        <div class=\"d-grid gap-2 d-md-block\">\n          <a href=\"https://documenter.getpostman.com/view/12963788/TVRg69g4\" target=\"_blank\" class=\"btn btn-primary px-5 py-2 shadow-sm\" style=\"border-radius: 10px; font-weight: 600;\">Lihat Dokumentasi</a>\n          <button type=\"button\" class=\"btn btn-link text-muted mt-2 d-block mx-auto\" data-bs-dismiss=\"modal\" data-dismiss=\"modal\" onclick=\"try { bootstrap.Modal.getInstance(document.getElementById('announcementModal')).hide(); } catch(e) { $('#announcementModal').modal('hide'); }\">Nanti saja</button>\n        </div>\n      </div>\n    </div>\n  </div>\n</div>\n\n<style>\n  #announcementModal .modal-content {\n    animation: modalPop 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n  }\n  \n  @keyframes modalPop {\n    from { opacity: 0; transform: scale(0.8); }\n    to { opacity: 1; transform: scale(1); }\n  }\n\n  .break-all {\n    word-break: break-all;\n  }\n  \n  #announcementModal .btn-primary {\n    transition: all 0.3s ease;\n  }\n  \n  #announcementModal .btn-primary:hover {\n    transform: translateY(-2px);\n    box-shadow: 0 5px 15px rgba(99, 102, 241, 0.4) !important;\n  }\n</style>\n\n<script>\n  // Robust popup trigger for footer\n  (function() {\n    function initAnnouncementModal() {\n      if (typeof bootstrap !== 'undefined' && document.getElementById('announcementModal')) {\n        setTimeout(function() {\n          var myModal = new bootstrap.Modal(document.getElementById('announcementModal'));\n          myModal.show();\n        }, 500);\n      } else {\n        // Retry if bootstrap not ready\n        setTimeout(initAnnouncementModal, 200);\n      }\n    }\n\n    // Only show on homepage to avoid being annoying\n    if (window.location.pathname === '/' || window.location.pathname === '') {\n        window.addEventListener('load', initAnnouncementModal);\n    }\n  })();\n</script>\n\n<script defer=\"\" src=\"https://static.cloudflareinsights.com/beacon.min.js/v833ccba57c9e4d2798f2e76cebdd09a11778172276447\" integrity=\"sha512-57MDmcccJXYtNnH+ZiBwzC4jb2rvgVCEokYN+L/nLlmO8rfYT/gIpW2A569iJ/3b+0UEasghjuZH/ma3wIs/EQ==\" data-cf-beacon=\"{&quot;version&quot;:&quot;2024.11.0&quot;,&quot;token&quot;:&quot;e4767fe0a18c42f897c278d5e3e605a9&quot;,&quot;r&quot;:1,&quot;server_timing&quot;:{&quot;name&quot;:{&quot;cfCacheStatus&quot;:true,&quot;cfEdge&quot;:true,&quot;cfExtPri&quot;:true,&quot;cfL4&quot;:true,&quot;cfOrigin&quot;:true,&quot;cfSpeedBrain&quot;:true},&quot;location_startswith&quot;:null}}\" crossorigin=\"anonymous\"></script>\n\n\n<div class=\"modal-backdrop fade show\"></div></body></html>",
